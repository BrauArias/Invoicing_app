# PowerHelp Landing
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Sirve index.html para requests exactos a la raiz
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^ /index.html [L]

# Ruta limpia para el panel de admin
RewriteRule ^settingdemo/?$ /settingdemo.html [L]

# BEGIN WordPress
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
# END WordPress
</IfModule>
